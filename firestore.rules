rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function isAdmin() {
      return signedIn()
        && exists(currentUserDoc())
        && get(currentUserDoc()).data.role == 'admin';
    }

    function roomDoc(roomId) {
      return /databases/$(database)/documents/rooms/$(roomId);
    }

    function callDoc(callId) {
      return /databases/$(database)/documents/calls/$(callId);
    }

    function hasParticipant(participantIds) {
      return participantIds is list
        && request.auth.uid in participantIds;
    }

    function isRoomParticipant(roomId) {
      return signedIn()
        && exists(roomDoc(roomId))
        && hasParticipant(get(roomDoc(roomId)).data.participantIds);
    }

    function validUserProfile(userId) {
      return request.resource.data.keys().hasOnly([
        'uid',
        'email',
        'nickname',
        'role',
        'status',
        'photoURL',
        'photoPath',
        'thirdPartyConsent',
        'thirdPartyConsentAt',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.uid == userId
      && request.resource.data.nickname is string
      && request.resource.data.nickname.size() >= 2
      && request.resource.data.nickname.size() <= 24
      && request.resource.data.role in ['user', 'admin']
      && request.resource.data.status in ['active', 'blocked']
      && (
        !request.resource.data.keys().hasAny(['photoURL'])
        || (
          request.resource.data.photoURL is string
          && request.resource.data.photoURL.size() <= 2048
        )
      )
      && (
        !request.resource.data.keys().hasAny(['photoPath'])
        || (
          request.resource.data.photoPath is string
          && request.resource.data.photoPath.matches('profileImages/' + userId + '/.*')
        )
      );
    }

    function validSelfProfileUpdate(userId) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'uid',
        'email',
        'nickname',
        'photoURL',
        'photoPath',
        'updatedAt'
      ])
      && (
        !request.resource.data.keys().hasAny(['uid'])
        || request.resource.data.uid == userId
      )
      && (
        !request.resource.data.keys().hasAny(['nickname'])
        || (
          request.resource.data.nickname is string
          && request.resource.data.nickname.size() >= 2
          && request.resource.data.nickname.size() <= 24
        )
      )
      && (
        !request.resource.data.keys().hasAny(['photoURL'])
        || (
          request.resource.data.photoURL is string
          && request.resource.data.photoURL.size() <= 2048
        )
      )
      && (
        !request.resource.data.keys().hasAny(['photoPath'])
        || (
          request.resource.data.photoPath is string
          && request.resource.data.photoPath.matches('profileImages/' + userId + '/.*')
        )
      )
      && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['updatedAt'])
        || request.resource.data.updatedAt == request.time
      );
    }

    function validReadReceipt(userId) {
      return request.resource.data.keys().hasOnly([
        'userId',
        'lastReadMessageId',
        'updatedAt',
        'expiresAt'
      ])
      && request.resource.data.userId == userId
      && request.resource.data.lastReadMessageId is string
      && request.resource.data.lastReadMessageId.size() > 0
      && request.resource.data.lastReadMessageId.size() <= 160
      && request.resource.data.updatedAt == request.time
      && request.resource.data.expiresAt is timestamp
      && request.resource.data.expiresAt > request.time;
    }

    function validMessageAttachment(roomId) {
      return !request.resource.data.keys().hasAny(['attachment'])
        || (
          request.resource.data.attachment is map
          && request.resource.data.attachment.keys().hasOnly([
            'kind',
            'name',
            'url',
            'path',
            'contentType',
            'size'
          ])
          && request.resource.data.attachment.kind in ['image', 'file']
          && request.resource.data.attachment.name is string
          && request.resource.data.attachment.name.size() > 0
          && request.resource.data.attachment.name.size() <= 160
          && request.resource.data.attachment.url is string
          && request.resource.data.attachment.url.size() > 0
          && request.resource.data.attachment.path is string
          && request.resource.data.attachment.path.matches(
            'chatFiles/' + roomId + '/' + request.auth.uid + '/.*'
          )
          && request.resource.data.attachment.contentType is string
          && request.resource.data.attachment.contentType.size() > 0
          && request.resource.data.attachment.contentType.size() <= 120
          && request.resource.data.attachment.size is int
          && request.resource.data.attachment.size > 0
          && request.resource.data.attachment.size <= 20 * 1024 * 1024
        );
    }

    function validSessionDescription(descriptionType, description) {
      return description is map
        && description.keys().hasOnly(['type', 'sdp'])
        && description.type == descriptionType
        && description.sdp is string
        && description.sdp.size() > 0
        && description.sdp.size() <= 200000;
    }

    function validCallCreate() {
      return request.resource.data.keys().hasOnly([
        'roomId',
        'callerId',
        'calleeId',
        'participantIds',
        'mode',
        'status',
        'offer',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.roomId is string
      && exists(roomDoc(request.resource.data.roomId))
      && get(roomDoc(request.resource.data.roomId)).data.type == 'direct'
      && request.resource.data.callerId == request.auth.uid
      && request.resource.data.calleeId is string
      && request.resource.data.calleeId != request.auth.uid
      && request.auth.uid in get(roomDoc(request.resource.data.roomId)).data.participantIds
      && request.resource.data.calleeId in get(roomDoc(request.resource.data.roomId)).data.participantIds
      && request.resource.data.participantIds is list
      && request.resource.data.participantIds.size() == 2
      && request.auth.uid in request.resource.data.participantIds
      && request.resource.data.calleeId in request.resource.data.participantIds
      && request.resource.data.mode in ['voice', 'video']
      && request.resource.data.status == 'ringing'
      && validSessionDescription('offer', request.resource.data.offer)
      && request.resource.data.createdAt == request.time
      && request.resource.data.updatedAt == request.time;
    }

    function validCallAnswer() {
      return request.auth.uid == resource.data.calleeId
        && resource.data.status == 'ringing'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'answer',
          'updatedAt'
        ])
        && request.resource.data.status == 'accepted'
        && validSessionDescription('answer', request.resource.data.answer)
        && request.resource.data.updatedAt == request.time;
    }

    function validCallEnd() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'status',
        'updatedAt',
        'endedAt'
      ])
      && request.resource.data.status in ['ended', 'declined']
      && (
        request.resource.data.status == 'ended'
        || request.auth.uid == resource.data.calleeId
      )
      && request.resource.data.updatedAt == request.time
      && request.resource.data.endedAt == request.time;
    }

    function validCallCandidate(callId, candidateSide) {
      return exists(callDoc(callId))
        && candidateSide in ['callerCandidates', 'calleeCandidates']
        && request.resource.data.keys().hasOnly([
          'candidate',
          'sdpMid',
          'sdpMLineIndex',
          'createdBy',
          'createdAt'
        ])
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.candidate is string
        && request.resource.data.candidate.size() > 0
        && request.resource.data.candidate.size() <= 4096
        && request.resource.data.sdpMid is string
        && request.resource.data.sdpMid.size() <= 120
        && request.resource.data.sdpMLineIndex is int
        && request.resource.data.sdpMLineIndex >= 0
        && (
          (
            candidateSide == 'callerCandidates'
            && request.auth.uid == get(callDoc(callId)).data.callerId
          )
          || (
            candidateSide == 'calleeCandidates'
            && request.auth.uid == get(callDoc(callId)).data.calleeId
          )
        );
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());

      allow create: if signedIn()
        && request.auth.uid == userId
        && validUserProfile(userId)
        && request.resource.data.role == 'user'
        && request.resource.data.status == 'active';

      allow update: if signedIn()
        && (
          (
            request.auth.uid == userId
            && validSelfProfileUpdate(userId)
          )
          || (
            isAdmin()
            && validUserProfile(userId)
          )
        );

      allow delete: if signedIn() && request.auth.uid == userId;
    }

    match /calls/{callId} {
      allow read: if signedIn()
        && (
          request.auth.uid == resource.data.callerId
          || request.auth.uid == resource.data.calleeId
        );

      allow create: if isAdmin()
        && validCallCreate();

      allow update: if signedIn()
        && (
          request.auth.uid == resource.data.callerId
          || request.auth.uid == resource.data.calleeId
        )
        && (validCallAnswer() || validCallEnd());

      allow delete: if false;

      match /{candidateSide}/{candidateId} {
        allow read: if signedIn()
          && exists(callDoc(callId))
          && (
            request.auth.uid == get(callDoc(callId)).data.callerId
            || request.auth.uid == get(callDoc(callId)).data.calleeId
          );

        allow create: if signedIn()
          && validCallCandidate(callId, candidateSide);

        allow update, delete: if false;
      }
    }

    match /rooms/{roomId} {
      allow list: if signedIn();

      allow get: if signedIn()
        && (isAdmin() || hasParticipant(resource.data.participantIds));

      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly([
          'name',
          'subtitle',
          'status',
          'type',
          'retentionPolicy',
          'participantIds',
          'createdBy',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 40
        && request.resource.data.type in ['direct', 'group']
        && request.resource.data.retentionPolicy in ['oneDay', 'oneMonth']
        && request.resource.data.participantIds is list
        && request.auth.uid in request.resource.data.participantIds;

      allow update: if isAdmin();
      allow delete: if false;

      match /readReceipts/{userId} {
        allow read: if signedIn()
          && (isAdmin() || isRoomParticipant(roomId));

        allow create, update: if signedIn()
          && request.auth.uid == userId
          && (isAdmin() || isRoomParticipant(roomId))
          && validReadReceipt(userId);

        allow delete: if false;
      }

      match /messages/{messageId} {
        allow read: if signedIn()
          && (isAdmin() || isRoomParticipant(roomId));

        allow create: if signedIn()
          && (isAdmin() || isRoomParticipant(roomId))
          && request.resource.data.keys().hasOnly([
            'roomId',
            'authorId',
            'authorName',
            'text',
            'attachment',
            'createdAt',
            'expiresAt'
          ])
          && request.resource.data.roomId == roomId
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.authorName is string
          && request.resource.data.authorName.size() > 0
          && request.resource.data.authorName.size() <= 24
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000
          && request.resource.data.createdAt == request.time
          && request.resource.data.expiresAt is timestamp
          && request.resource.data.expiresAt > request.time
          && validMessageAttachment(roomId);

        allow update, delete: if false;
      }
    }
  }
}
