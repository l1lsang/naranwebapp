rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validUpload(maxBytes) {
      return request.resource != null
        && request.resource.size > 0
        && request.resource.size <= maxBytes;
    }

    function validImageUpload(maxBytes) {
      return validUpload(maxBytes)
        && request.resource.contentType.matches('image/.*');
    }

    match /chatFiles/{roomId}/{userId}/{fileName} {
      allow read: if signedIn();

      allow write: if isOwner(userId)
        && validUpload(20 * 1024 * 1024);
    }

    match /profileImages/{userId}/{fileName=**} {
      allow read: if signedIn();

      allow create, update: if isOwner(userId)
        && validImageUpload(5 * 1024 * 1024);

      allow delete: if isOwner(userId);
    }

    match /roomImages/{roomId}/{userId}/{fileName=**} {
      allow read: if signedIn();

      allow create, update: if isOwner(userId)
        && validImageUpload(5 * 1024 * 1024);

      allow delete: if isOwner(userId);
    }
  }
}
